<html>
<head>
  <meta http-equiv="Content-Type" content="text/html;charset=utf-8">
  <meta charset="utf-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <title>军师棋牌</title>
  <style>
html,body{overflow:hidden}
body{margin:0;background:#1b1b1b}
body>div{position:relative;overflow:hidden}
body>div>ul{display:inline-block;margin:0;padding:0;list-style:none;white-space:nowrap;font-size:12px;color:#fff}
body>div li{line-height:20px;display:inline-block;padding:0 12px}
body>div li *{height:20px;line-height:20px}
body>textarea{display:none}
  </style>
</head>
<body scroll="no">
  欢迎来到军师棋牌
</body>
</html>